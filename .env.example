# SignUpGenius page URL to scrape
SIGNUP_GENIUS_URL=

# Comma-separated list of recipient email addresses
EMAIL_RECIPIENTS=person1@example.com,person2@example.com

# Teacher name used in the email greeting
TEACHER_NAME=Mr S

# Gmail credentials for sending
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: override target date (YYYY-MM-DD). If not set, defaults to tomorrow.
TARGET_DATE=

# Last date to send reminders for (YYYY-MM-DD). Skips silently after this date.
END_DATE=2026-06-10

# Optional: set to "true" to save a debug screenshot of the page
DEBUG_SCREENSHOT=false
